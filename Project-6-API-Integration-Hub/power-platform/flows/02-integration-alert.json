{
  "properties": {
    "displayName": "HUB-02 Integration Failure Alert",
    "description": "Triggered by the Quickbase automation when an event enters Dead Letter or a route's failure rate exceeds 20%. Routes the alert to the correct system owner and posts to the integrations Teams channel.",
    "state": "Started",
    "definition": {
      "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
      "contentVersion": "1.0.0.0",
      "parameters": {
        "$connections":     { "defaultValue": {}, "type": "Object" },
        "$authentication":  { "defaultValue": {}, "type": "SecureObject" },
        "OpsEmail":         { "defaultValue": "integration-ops@yourcompany.com", "type": "String" },
        "TeamsWebhookUrl":  { "defaultValue": "", "type": "String" }
      },
      "triggers": {
        "When_HTTP_Request_Received": {
          "type": "Request",
          "kind": "Http",
          "inputs": {
            "schema": {
              "type": "object",
              "required": ["eventId", "source", "eventType"],
              "properties": {
                "eventId":        { "type": "string" },
                "source":         { "type": "string" },
                "eventType":      { "type": "string" },
                "routeLabel":     { "type": "string" },
                "errorMessage":   { "type": "string" },
                "retryCount":     { "type": "integer" },
                "alertType":      { "type": "string" },
                "failureRatePct": { "type": "number" }
              }
            }
          }
        }
      },
      "actions": {

        "Is_DLQ_Alert": {
          "type": "Condition",
          "runAfter": {},
          "expression": { "or": [
            { "equals": ["@triggerBody()?['alertType']", "dead_letter"] },
            { "equals": ["@triggerBody()?['retryCount']", 5] }
          ]},
          "actions": {
            "Send_Critical_DLQ_Alert": {
              "type": "ApiConnection",
              "inputs": {
                "host": { "connection": { "name": "@parameters('$connections')['office365']['connectionId']" } },
                "method": "post",
                "path": "/v2/Mail/Send",
                "body": {
                  "To": "@parameters('OpsEmail')",
                  "Subject": "🚨 Integration Dead Letter: @{triggerBody()?['eventId']} (@{triggerBody()?['source']} → @{triggerBody()?['eventType']})",
                  "Body": "<div style='border-left:5px solid #E74C3C;padding:16px;font-family:Arial'><h3 style='color:#E74C3C'>Integration Event in Dead Letter Queue</h3><table><tr><td><b>Event ID</b></td><td>@{triggerBody()?['eventId']}</td></tr><tr><td><b>Route</b></td><td>@{triggerBody()?['routeLabel']}</td></tr><tr><td><b>Retries</b></td><td>@{triggerBody()?['retryCount']}</td></tr><tr><td><b>Error</b></td><td>@{triggerBody()?['errorMessage']}</td></tr></table><p>Manual investigation required. <a href='https://yourcompany.quickbase.com'>View DLQ in Quickbase</a></p></div>",
                  "IsHtml": true
                }
              }
            }
          },
          "else": {
            "actions": {
              "Send_Route_Failure_Warning": {
                "type": "ApiConnection",
                "inputs": {
                  "host": { "connection": { "name": "@parameters('$connections')['office365']['connectionId']" } },
                  "method": "post",
                  "path": "/v2/Mail/Send",
                  "body": {
                    "To": "@parameters('OpsEmail')",
                    "Subject": "⚠ Integration Degraded: @{triggerBody()?['source']} failure rate @{triggerBody()?['failureRatePct']}%",
                    "Body": "<p>Route <b>@{triggerBody()?['routeLabel']}</b> has a failure rate of <b>@{triggerBody()?['failureRatePct']}%</b> today.</p><p>Latest error: @{triggerBody()?['errorMessage']}</p>",
                    "IsHtml": true
                  }
                }
              }
            }
          }
        },

        "Post_Alert_to_Teams": {
          "type": "Http",
          "runAfter": { "Is_DLQ_Alert": ["Succeeded"] },
          "inputs": {
            "method": "POST",
            "uri": "@parameters('TeamsWebhookUrl')",
            "body": {
              "type": "message",
              "attachments": [{
                "contentType": "application/vnd.microsoft.card.adaptive",
                "content": {
                  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
                  "type": "AdaptiveCard",
                  "version": "1.4",
                  "body": [
                    { "type": "TextBlock", "text": "@{if(or(equals(triggerBody()?['alertType'], 'dead_letter'), equals(triggerBody()?['retryCount'], 5)), '🚨', '⚠')} Integration Alert", "weight": "Bolder", "size": "Medium", "color": "@{if(or(equals(triggerBody()?['alertType'], 'dead_letter'), equals(triggerBody()?['retryCount'], 5)), 'Attention', 'Warning')}" },
                    { "type": "FactSet", "facts": [
                      { "title": "Event ID",  "value": "@{triggerBody()?['eventId']}" },
                      { "title": "Route",     "value": "@{triggerBody()?['routeLabel']}" },
                      { "title": "Retries",   "value": "@{triggerBody()?['retryCount']}" },
                      { "title": "Error",     "value": "@{first(split(triggerBody()?['errorMessage'], chr(10)))}" }
                    ]}
                  ],
                  "actions": [{ "type": "Action.OpenUrl", "title": "View in Quickbase", "url": "https://yourcompany.quickbase.com" }]
                }
              }]
            }
          }
        }

      }
    }
  }
}
